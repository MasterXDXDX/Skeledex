{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-utils/schema.json",
  "productName": "Skeledex",
  "version": "1.0.6",
  "identifier": "com.servidortecnico.panel",
  "bundle": {
    "active": true,
    "icon": ["icons/icon.ico", "icons/icon.png"]
  },
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Skeledex",
        "width": 920,
        "height": 680,
        "minWidth": 720,
        "minHeight": 560,
        "resizable": true,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  }
}
